# ─────────────────────────────────────────────────────────────────────────────
# MetaTrade — Environment Configuration
# Copy to .env and fill in your values.  Never commit .env to git.
#
# NOTA PREFISSI: ogni sezione usa il proprio prefisso (RUNNER_, ML_, ALERT_…).
# Le variabili senza prefisso sono solo per il logging.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_MB=20
LOG_BACKUP_DAYS=30

# ─── MetaTrader 5 (prefisso: MARKET_DATA_) ────────────────────────────────────
MARKET_DATA_MT5_LOGIN=0
MARKET_DATA_MT5_PASSWORD=
MARKET_DATA_MT5_SERVER=
MARKET_DATA_MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MARKET_DATA_MT5_TIMEOUT_MS=60000
MARKET_DATA_DUCKDB_PATH=data/bars.duckdb
MARKET_DATA_SQLITE_PATH=data/operational.db
MARKET_DATA_WARMUP_BARS=500

# ─── Runner (prefisso: RUNNER_) ────────────────────────────────────────────────
# Simbolo e timeframe di default (possono essere override via CLI --symbol --timeframe)
RUNNER_SYMBOL=EURUSD
RUNNER_MAX_RISK_PCT=0.01
RUNNER_DAILY_LOSS_LIMIT_PCT=0.05
RUNNER_AUTO_KILL_DRAWDOWN_PCT=0.10
RUNNER_MAX_OPEN_POSITIONS=1
RUNNER_MAX_SPREAD_PIPS=3.0
RUNNER_SIGNAL_COOLDOWN_BARS=3
RUNNER_PAPER_INITIAL_BALANCE=10000.0

# Sessione di trading: entra solo tra START e END (ora UTC, 0-23)
# Esempio: Londra+NY = dalle 07 alle 21 UTC
RUNNER_SESSION_FILTER_UTC_START=7
RUNNER_SESSION_FILTER_UTC_END=21

# ─── Risk (prefisso: RISK_) ────────────────────────────────────────────────────
RISK_MAX_RISK_PCT=0.01
RISK_MAX_OPEN_POSITIONS=1
RISK_MAX_SPREAD_PIPS=3.0
RISK_DAILY_LOSS_LIMIT_PCT=0.05
RISK_AUTO_KILL_DRAWDOWN_PCT=0.10

# ─── ML (prefisso: ML_) ────────────────────────────────────────────────────────
ML_MODEL_REGISTRY_DIR=data/models

# Walk-forward training
ML_TRAIN_WINDOW_BARS=2000
ML_TEST_WINDOW_BARS=500
ML_STEP_BARS=250
ML_FORWARD_BARS=5
ML_ATR_THRESHOLD_MULT=0.8
ML_HOLDOUT_FRACTION=0.2

# Sessione per il training (stessa della sessione live, esclude ore off-market)
ML_SESSION_FILTER_UTC_START=7
ML_SESSION_FILTER_UTC_END=21

# Live accuracy tracker
ML_LIVE_ACCURACY_MIN_SAMPLES=200
ML_LIVE_ACCURACY_WARNING_BELOW=0.50

# Model watcher — switch automatico quando arriva modello migliore su disco
ML_MODEL_WATCHER_ENABLED=true
ML_MODEL_WATCHER_POLL_SEC=120
ML_CANDIDATE_MIN_HOLDOUT=0.52

# Retraining in background
ML_RETRAIN_ENABLED=true
ML_RETRAIN_TRIGGER=hours       # hours | bars
ML_RETRAIN_EVERY_HOURS=3       # usato se TRIGGER=hours
ML_RETRAIN_EVERY_BARS=5000     # usato se TRIGGER=bars
# Sorgente dati retrain: mt5 (default) | massive (API Massive; con Mongo il worker scarica, niente upload barre)
ML_RETRAIN_SOURCE=mt5
# Con massive: ogni retrain schedulato aggiunge --massive-refresh (riscarico CSV). One-shot: Telegram /retrain_refresh
ML_RETRAIN_MASSIVE_REFRESH=false
# Passa --adaptive a train.py nel retrain (disattiva per run più corti)
ML_RETRAIN_ADAPTIVE=true
ML_BACKEND=xgboost             # histgbm | lightgbm | xgboost | catboost
ML_USE_GPU=false               # true = abilita GPU (xgboost/catboost: CUDA, lightgbm: OpenCL/CUDA); histgbm ignora
ML_CLASS_WEIGHT=balanced       # balanced = pesi automatici per classi sbilanciate (HOLD-dominated); null = pesi uniformi
ML_MIN_ACCURACY=0.56

# Target precision per fermare il loop adattivo (separati per BUY e SELL).
# Il loop si ferma quando ENTRAMBI i target sono raggiunti.
# Se non raggiunti dopo 20 tentativi, viene salvato il miglior modello trovato.
ML_TARGET_BUY_PRECISION=0.55
ML_TARGET_SELL_PRECISION=0.55

# Floor minimo: se dopo tutti i tentativi nessun backend raggiunge i target,
# viene accettato il miglior modello trovato solo se >= questo valore.
# Se non lo raggiunge, il training è considerato fallito.
ML_ADAPTIVE_FALLBACK_MIN=0.50

# Backend multipli (separati da |): lancia un job parallelo per backend.
# Il primo che raggiunge i target viene promosso subito. Alla fine vince il migliore.
# ML_BACKEND=histgbm|lightgbm|xgboost

# Numero massimo di job paralleli sul worker (uno per backend).
ML_WORKER_MAX_PARALLEL_JOBS=1

# ─── Distributed ML training via MongoDB Atlas (opzionale) ────────────────────
# Lascia ML_TRAIN_MONGO=false per usare il training locale (comportamento default).
#
# Comportamento per combinazione di flag:
#   ML_TRAIN_MONGO=false  → training locale subprocess (default)
#   ML_TRAIN_MONGO=true  + ML_MT5_MASTER=true  → master: push job su MongoDB
#   ML_TRAIN_MONGO=true  + ML_MT5_MASTER=false → worker: polling MongoDB ed esecuzione training
#
ML_TRAIN_MONGO=false

# Ruolo della macchina:
#   true  = master (ha MT5 + Telegram; triggera il training e scarica il modello)
#   false = worker (macchina potente senza MT5; esegue il training e carica il modello)
ML_MT5_MASTER=true

# MongoDB Atlas connection string (obbligatorio se ML_TRAIN_MONGO=true)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DB=metatrade

# Intervallo di polling del worker quando idle (secondi)
ML_WORKER_POLL_SEC=30

# ─── Telegram (prefisso: ALERT_) ──────────────────────────────────────────────
# Per ottenere bot_token: parla con @BotFather su Telegram → /newbot
# Per il chat_id: aggiungi @userinfobot al tuo canale/gruppo e manda un messaggio
ALERT_BOT_TOKEN=
ALERT_CHAT_ID=
ALERT_ENABLED=true
ALERT_MIN_PNL_ALERT=0.0
ALERT_THROTTLE_SEC=60
ALERT_DAILY_SUMMARY_HOUR_UTC=21

# Notifiche per categoria (true = attiva, false = disattiva)
ALERT_NOTIFY_TRADE_OPENED=true
ALERT_NOTIFY_TRADE_CLOSED=true
ALERT_NOTIFY_TRADE_SL_MOVED=false      # noisy, opt-in
ALERT_NOTIFY_SESSION_START=true
ALERT_NOTIFY_SESSION_END=true
ALERT_NOTIFY_DAILY_SUMMARY=true
ALERT_NOTIFY_MODEL_EVENTS=true
ALERT_NOTIFY_ACCURACY_CHECKPOINT=false # opt-in
ALERT_NOTIFY_SPREAD_BLOCKED=false      # molto noisy, opt-in
ALERT_NOTIFY_SYSTEM_ERRORS=true
ALERT_NOTIFY_RETRAIN_EVENTS=true

# Comandi in entrata via Telegram (/status, /pause, /stop, ecc.)
ALERT_COMMANDS_ENABLED=true
ALERT_POLL_INTERVAL_SEC=3

# ─── Massive.com (Forex REST, training / download) ───────────────────────────
# Piano Currencies Basic: ~5 richieste/min → download lento; cache in data/massive
MASSIVE_API_KEY=
# MASSIVE_BASE_URL=https://api.massive.com
# MASSIVE_MIN_REQUEST_INTERVAL_SEC=13
# MASSIVE_GAP_FILL_MAX_BARS=5
# MASSIVE_MAX_HISTORY_DAYS=730

# ─── Observability / Dashboard (prefisso: OBSERVABILITY_) ────────────────────
OBSERVABILITY_HOST=0.0.0.0
OBSERVABILITY_PORT=8080
