# ─────────────────────────────────────────────────────────────
# MetaTrade — Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# Run mode: BACKTEST | PAPER | LIVE
RUN_MODE=PAPER

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_AS_JSON=true

# ─── Market Data ──────────────────────────────────────────────
# Symbols to trade (comma-separated)
SYMBOLS=EURUSD,GBPUSD,USDJPY

# Timeframe for analysis (M1, M5, M15, M30, H1, H4, D1)
PRIMARY_TIMEFRAME=H1

# Number of bars to load on startup
WARMUP_BARS=500

# ─── MetaTrader 5 ─────────────────────────────────────────────
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_TIMEOUT_MS=60000

# ─── Database ─────────────────────────────────────────────────
DB_PATH=data/market_data.db

# ─── Risk Management ──────────────────────────────────────────
RISK_PCT_PER_TRADE=0.01
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_PCT=0.03
MAX_DRAWDOWN_PCT=0.15
MAX_SPREAD_PIPS=3.0
MIN_RISK_REWARD_RATIO=1.5
MAX_LOT_SIZE=1.0

# ─── Consensus Engine ─────────────────────────────────────────
CONSENSUS_MODE=SIMPLE_VOTE
CONSENSUS_THRESHOLD=0.60

# ─── Kill Switch ──────────────────────────────────────────────
KILL_SWITCH_FILE=/tmp/metatrade_kill.lock

# ─── ML ───────────────────────────────────────────────────────
MODEL_REGISTRY_PATH=models/
MAX_MODEL_AGE_DAYS=30
MIN_TRAINING_BARS=5000
WALK_FORWARD_TRAIN_BARS=10000
WALK_FORWARD_VAL_BARS=2000
WALK_FORWARD_STEP_BARS=1000
